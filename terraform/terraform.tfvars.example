# Copy to terraform.tfvars and adjust as needed.

aws_region   = "ap-south-2"
project_name = "familytree"
environment  = "prod"

existing_instance_id      = "i-05110a66209f176ee"
existing_security_group_id = "sg-0dfe3c93640c7a919"
vpc_id                    = "vpc-0023ad5cadf288fd2"

# Update this if your IP changes - it gates SSH access to the instance.
ssh_allowed_cidr = "111.92.34.103/32"

mfa_configuration          = "OPTIONAL"
password_minimum_length    = 12
access_token_validity_hours = 1
refresh_token_validity_days = 30

# Google OAuth 2.0 Web application credentials (Google Cloud Console > APIs & Services > Credentials).
# Do not put real values here - copy this file to terraform.tfvars (gitignored) and fill them in there.
google_client_id     = "REPLACE_ME.apps.googleusercontent.com"
google_client_secret = "REPLACE_ME"

# Cognito requires https:// for non-localhost callback/logout URLs. Add your production HTTPS URL
# here once a domain + TLS cert exist for the app; until then this stays localhost-only.
oauth_callback_urls = ["http://localhost:8080/"]

# Must be a verified SES identity (or domain) in your AWS account - the Contact Us
# feature is only permitted to send email as this address.
ses_sender_email = "REPLACE_ME@example.com"
