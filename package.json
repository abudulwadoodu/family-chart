{
  "name": "family-chart",
  "version": "0.9.0",
  "type": "module",
  "description": "family tree creator and viewer",
  "keywords": [
    "datafull",
    "family-chart",
    "family tree",
    "d3"
  ],
  "homepage": "https://donatso.github.io/family-chart/",
  "license": "SEE LICENSE IN LICENSE.txt",
  "author": {
    "name": "donatso"
  },
  "main": "dist/family-chart.js",
  "types": "dist/types/index.d.ts",
  "unpkg": "dist/family-chart.min.js",
  "module": "dist/family-chart.esm.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/family-chart.esm.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/family-chart.js"
      }
    },
    "./styles/*": "./dist/styles/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donatso/family-chart.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/styles/**",
    "dist/types/**"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "cypress open",
    "test-run": "cypress run",
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:backend": "node backend/server.js",
    "dev:app": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:seed": "node backend/db/seed.js",
    "docs": "typedoc",
    "docs:deploy": "yarn docs && gh-pages -d docs/api -b gh-pages",
    "prepublishOnly": "node prePublish.js"
  },
  "sideEffects": false,
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/d3": "^7.4.3",
    "concurrently": "^9.2.1",
    "cypress": "15.2.0",
    "gh-pages": "^6.3.0",
    "http-server": "^14.1.1",
    "rollup": "^4.45.1",
    "typedoc": "^0.28.13",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
