# Frontend (Vite) — copy to .env.development / .env.production as needed.
# Only variables prefixed with VITE_ are exposed to the browser.
#
# Production static deploy: run `npm run build:app`, then point Nginx root at `dist/app`
# (same repo root as this file). Use try_files for SPA fallback if you add client routes later.

# Optional API origin prefix (no trailing slash). Leave empty for same-origin /api (Nginx proxy or Vite dev proxy).
# VITE_API_BASE=

# Public path when the app is served from a subpath (must end with / if set). Default /.
# VITE_BASE=/

# Backend URL for Vite dev server proxy only (not bundled).
# VITE_DEV_API_ORIGIN=http://localhost:3001

# --- Backend (node backend/server.js) ---
# Copy these into backend/.env (or your process environment) — not exposed to the browser.

# PORT=3001
# FRONTEND_ORIGIN=http://localhost:8080
# DB_PATH=data/app.db

# Cookie settings for the auth session cookies.
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# JWT signing secrets — set strong random values in production.
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# ACCESS_TOKEN_TTL_MS=900000
# REFRESH_TOKEN_TTL_MS=2592000000

# Email OTP login.
# OTP_EXPIRY_MINUTES=5
# OTP_MAX_ATTEMPTS=5
# OTP_REQUEST_RATE_LIMIT_WINDOW_MS=900000
# OTP_REQUEST_RATE_LIMIT_MAX=5
# OTP_VERIFY_RATE_LIMIT_WINDOW_MS=900000
# OTP_VERIFY_RATE_LIMIT_MAX=20

# Email delivery provider: console (logs to stdout, default/dev), ses (AWS SES), or memory (tests).
# EMAIL_PROVIDER=console
# EMAIL_FROM=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
