# Frontend (Vite) — copy to .env.development / .env.production as needed.
# Only variables prefixed with VITE_ are exposed to the browser.
#
# Production static deploy: run `npm run build:app`, then point Nginx root at `dist/app`
# (same repo root as this file). Use try_files for SPA fallback if you add client routes later.

# Optional API origin prefix (no trailing slash). Leave empty for same-origin /api (Nginx proxy or Vite dev proxy).
# VITE_API_BASE=

# Public path when the app is served from a subpath (must end with / if set). Default /.
# VITE_BASE=/

# Backend URL for Vite dev server proxy only (not bundled).
# VITE_DEV_API_ORIGIN=http://localhost:3001

# Cognito User Pool + SPA client used by the frontend (Amplify Auth v6).
# Get these from `terraform output cognito_user_pool_id` / `cognito_user_pool_client_id`
# after applying terraform/.
# VITE_COGNITO_USER_POOL_ID=
# VITE_COGNITO_CLIENT_ID=
# VITE_AWS_REGION=ap-south-2

# Cognito Hosted UI domain, used for the Google sign-in redirect flow.
# Get this from `terraform output cognito_oauth_domain` after applying terraform/.
# VITE_COGNITO_OAUTH_DOMAIN=

# Support email shown on the Contact Us page's "Other ways to reach us" card.
# VITE_SUPPORT_EMAIL=support@example.com

# --- Backend (node backend/server.js) ---
# Copy these into backend/.env (or your process environment) — not exposed to the browser.

# PORT=3001
# FRONTEND_ORIGIN=http://localhost:8080
# Production: FRONTEND_ORIGIN=https://circlebook.life
# Used for CORS (backend/app.js) and the ticket link in support emails (backend/utils/supportEmail.js) —
# must be the real browser-facing origin, not the EC2 instance's public IP (which can change).
# DB_PATH=data/app.db

# Cognito User Pool the backend verifies ID tokens against (same pool as above).
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# Amazon SES, used to email support ticket notifications (created/replied/resolved/closed).
# Both SES_SENDER_EMAIL and SES_RECIPIENT_EMAIL are required - the backend refuses to send
# without them. The sender address must be a verified SES identity (or domain) in the target
# region; until SES is out of the account's sandbox, the recipient address must be verified
# too. AWS credentials are resolved via the default SDK credential chain (env vars / IAM role).
# SES_REGION=ap-south-2
# SES_SENDER_EMAIL=
# SES_RECIPIENT_EMAIL=

# Comma-separated list of emails granted admin access to the Admin Portal (Contact Requests,
# etc). Checked and applied to the local users table on every login - there's no UI yet to
# grant the role, so add/remove emails here and have the user sign in again to take effect.
# ADMIN_EMAILS=admin@example.com

# --- Seed script only (backend/db/seed.js), not needed to run the server ---
# Requires AWS credentials with Cognito admin permissions to provision the 3 demo users.
# SEED_DEMO_PASSWORD=
# AWS_REGION=ap-south-2
